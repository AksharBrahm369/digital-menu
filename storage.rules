rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Paths matching: /restaurants/{restaurantId}/...
    match /restaurants/{restaurantId}/{allPaths=**} {
      // Anyone can read images, PDFs, logos, QR exports
      allow read: if true;
      
      // Write access is restricted to authenticated users
      allow write: if isSignedIn();
    }
  }
}
